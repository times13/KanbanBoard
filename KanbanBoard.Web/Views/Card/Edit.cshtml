@{
}
@model KanbanBoard.LibrairieMetier.ViewModels.EditCardViewModel

@{
    ViewData["Title"] = "Modifier la carte";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-7">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>✏️ Modifier la carte</h2>
            <a asp-controller="Board" asp-action="Details" asp-route-id="@Model.BoardId" class="btn btn-outline-secondary btn-sm">
                ← Retour au tableau
            </a>
        </div>

        @* ============ Formulaire d'édition ============ *@
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="BoardId" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" autofocus />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Priority" class="form-label"></label>
                    <select asp-for="Priority" class="form-select">
                        <option value="Low">🟢 Basse</option>
                        <option value="Medium">🟡 Moyenne</option>
                        <option value="High">🟠 Haute</option>
                        <option value="Critical">🔴 Critique</option>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="DueDate" class="form-label"></label>
                    <input asp-for="DueDate" type="date" class="form-control" />
                    <span asp-validation-for="DueDate" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">💾 Enregistrer</button>
            </div>
        </form>

    @if (ViewData["IsAdmin"] is true)
    {
            @* Formulaire pour la suppression (HTML interdit les forms imbriqués) *@
            <form asp-action="Delete" method="post"
            class="mt-3"
              onsubmit="return confirm('⚠️ Supprimer définitivement cette carte ?\n\n« @Model.Title »');">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="boardId" value="@Model.BoardId" />
            <button type="submit" class="btn btn-outline-danger btn-sm">🗑️ Supprimer cette carte</button>
        </form>
    }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}