    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
@model KanbanBoard.LibrairieMetier.ViewModels.EditCardViewModel

@{
    ViewData["Title"] = "Modifier la carte";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-7">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>✏️ Modifier la carte</h2>
            <a asp-controller="Board" asp-action="Details" asp-route-id="@Model.BoardId" class="btn btn-outline-secondary btn-sm">
                ← Retour au tableau
            </a>
        </div>

        @* ============ Messages TempData ============ *@
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @* ============ Bandeau lecture seule ============ *@
        @if (ViewData["CanWrite"] is false)
        {
            <div class="alert alert-info" role="alert">
                👁️ <strong>Mode lecture seule</strong> — Vous êtes en tant que Viewer sur ce tableau et ne pouvez ni modifier la carte, ni commenter.
            </div>
        }

        @* ============ Formulaire d'édition ============ *@
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="BoardId" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                @if (ViewData["CanWrite"] is false)
                {
                    <input asp-for="Title" class="form-control" disabled />
                }
                else
                {
                    <input asp-for="Title" class="form-control" autofocus />
                }
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                @if (ViewData["CanWrite"] is false)
                {
                    <textarea asp-for="Description" class="form-control" rows="5" disabled></textarea>
                }
                else
                {
                    <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                }
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Priority" class="form-label"></label>
                    @if (ViewData["CanWrite"] is false)
                    {
                        <select asp-for="Priority" class="form-select" disabled>
                            <option value="Low">🟢 Basse</option>
                            <option value="Medium">🟡 Moyenne</option>
                            <option value="High">🟠 Haute</option>
                            <option value="Critical">🔴 Critique</option>
                        </select>
                    }
                    else
                    {
                        <select asp-for="Priority" class="form-select">
                            <option value="Low">🟢 Basse</option>
                            <option value="Medium">🟡 Moyenne</option>
                            <option value="High">🟠 Haute</option>
                            <option value="Critical">🔴 Critique</option>
                        </select>
                    }
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="DueDate" class="form-label"></label>
                    @if (ViewData["CanWrite"] is false)
                    {
                        <input asp-for="DueDate" type="date" class="form-control" disabled />
                    }
                    else
                    {
                        <input asp-for="DueDate" type="date" class="form-control" />
                    }
                    <span asp-validation-for="DueDate" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="AssigneeId" class="form-label"></label>
                    @if (ViewData["CanWrite"] is false)
                    {
                        <select asp-for="AssigneeId" class="form-select" disabled>
                            <option value="">— Personne —</option>
                            @foreach (var member in Model.AvailableMembers)
                            {
                                <option value="@member.UserId">
                                    @member.Username (@member.Role)
                                </option>
                            }
                        </select>
                    }
                    else
                    {
                        <select asp-for="AssigneeId" class="form-select">
                            <option value="">— Personne —</option>
                            @foreach (var member in Model.AvailableMembers)
                            {
                                <option value="@member.UserId">
                                    @member.Username (@member.Role)
                                </option>
                            }
                        </select>
                    }
                    <span asp-validation-for="AssigneeId" class="text-danger"></span>
                </div>
            </div>

            @if (ViewData["CanWrite"] is true)
            {
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">💾 Enregistrer</button>
                </div>
            }
        </form>

    @if (ViewData["IsAdmin"] is true)
    {
            @* Formulaire pour la suppression (HTML interdit les forms imbriqués) *@
            <form asp-action="Delete" method="post"
            class="mt-3"
              onsubmit="return confirm('⚠️ Supprimer définitivement cette carte ?\n\n« @Model.Title »');">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="boardId" value="@Model.BoardId" />
            <button type="submit" class="btn btn-outline-danger btn-sm">🗑️ Supprimer cette carte</button>
        </form>
    }

        @* ============ Section commentaires ============ *@
        <hr class="my-5" />

        <div class="row justify-content-center">
            <div class="col-md-12">
                <h4 class="mb-3">💬 Commentaires <span class="badge bg-secondary">@Model.Comments.Count</span></h4>

                @* Formulaire ajout commentaire — uniquement pour les non-Viewers *@
                @if (ViewData["CanWrite"] is true)
                {
                    <form asp-controller="Comment" asp-action="Add" method="post" class="mb-4">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="cardId" value="@Model.Id" />
                        <input type="hidden" name="boardId" value="@Model.BoardId" />

                        <div class="mb-2">
                            <textarea name="content" class="form-control"
                                  rows="2" maxlength="2000"
                                  placeholder="Écrire un commentaire..."
                                  required></textarea>
                        </div>
                        <button type="submit" class="btn btn-sm btn-primary">Commenter</button>
                    </form>
                }
                else
                {
                    <p class="text-muted small mb-3">
                        🔒 Les commentaires sont visibles mais vous ne pouvez pas en ajouter en mode lecture seule.
                    </p>
                }

                @* Liste des commentaires *@
                @if (!Model.Comments.Any())
                {
                    <p class="text-muted text-center py-3">Aucun commentaire pour cette carte.</p>
                }
                else
                {
                    var currentUserId = ViewData["CurrentUserId"] as int? ?? 0;
                    var isAdmin = ViewData["IsAdmin"] is true;

                    foreach (var comment in Model.Comments)
                    {
                        var canDelete = comment.AuthorId == currentUserId || isAdmin;

                        <div class="card mb-2 shadow-sm">
                            <div class="card-body py-2">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <strong>@comment.AuthorUsername</strong>
                                        <small class="text-muted ms-2">
                                            @comment.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                        </small>
                                    </div>
                                    @if (canDelete)
                                    {
                                        <form asp-controller="Comment" asp-action="Delete" method="post"
                                              onsubmit="return confirm('Supprimer ce commentaire ?');"
                                              class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@comment.Id" />
                                            <button type="submit" class="btn btn-sm btn-link text-danger p-0"
                                                    title="Supprimer">
                                                ✕
                                            </button>
                                        </form>
                                    }
                                </div>
                                <p class="mb-0 mt-1" style="white-space: pre-wrap;">@comment.Content</p>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // ============ Configuration ============
            const boardId = @Model.BoardId;
            const currentCardId = @Model.Id;
            const currentUser = @Html.Raw(Json.Serialize(User.Identity?.Name ?? ""));

            // ============ Connexion SignalR ============
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/kanbanHub")
                .withAutomaticReconnect()
                .configureLogging(signalR.LogLevel.Warning)
                .build();

            // ============ Réception des événements ============
            connection.on("BoardChanged", function (payload) {
                // Ignorer mes propres actions
                if (payload.triggeredBy === currentUser) return;

                // Détermine si l'événement concerne CETTE carte
                const isAboutThisCard = payload.cardId === currentCardId;

                showLiveNotification(payload, isAboutThisCard);

                // Reload SEULEMENT si c'est la même carte
                if (isAboutThisCard) {
                    setTimeout(() => location.reload(), 1500);
                }
            });

            connection.on("CardMoved", function (payload) {
                if (payload.triggeredBy === currentUser) return;

                const isAboutThisCard = payload.cardId === currentCardId;

                showLiveNotification({
                    action: "CardMoved",
                    title: "",
                    triggeredBy: payload.triggeredBy,
                    cardId: payload.cardId
                }, isAboutThisCard);

                if (isAboutThisCard) {
                    setTimeout(() => location.reload(), 1500);
                }
            });

            // Démarrer la connexion + rejoindre le groupe
            connection.start()
                .then(() => connection.invoke("JoinBoard", boardId))
                .catch(err => console.error("SignalR error:", err));

            // Quitter le groupe à la sortie de page
            window.addEventListener("beforeunload", () => {
                connection.invoke("LeaveBoard", boardId).catch(() => {});
            });
        });

        // ============ Helper toast ============
        function showLiveNotification(payload, isAboutThisCard) {
            const messages = {
                "CardCreated":   `🆕 Nouvelle carte « ${payload.title} » par ${payload.triggeredBy}`,
                "CardUpdated":   `✏️ Carte « ${payload.title} » modifiée par ${payload.triggeredBy}`,
                "CardDeleted":   `🗑️ Une carte a été supprimée par ${payload.triggeredBy}`,
                "CardMoved":     `↔️ Une carte a été déplacée par ${payload.triggeredBy}`,
                "CommentAdded":  `💬 Nouveau commentaire par ${payload.triggeredBy}`,
                "CommentDeleted":`💬 Commentaire supprimé par ${payload.triggeredBy}`,
                "ColumnCreated": `➕ Nouvelle colonne « ${payload.title} » par ${payload.triggeredBy}`,
                "ColumnRenamed": `✏️ Colonne renommée en « ${payload.title} » par ${payload.triggeredBy}`,
                "ColumnDeleted": `🗑️ Une colonne a été supprimée par ${payload.triggeredBy}`
            };
            const msg = messages[payload.action] || `Mise à jour : ${payload.action}`;

            const toast = document.createElement('div');
            // Couleur différente selon "concerne moi ou pas"
            toast.className = isAboutThisCard
                ? 'position-fixed top-0 end-0 m-3 alert alert-warning shadow'
                : 'position-fixed top-0 end-0 m-3 alert alert-info shadow';
            toast.style.zIndex = 9999;
            toast.style.minWidth = '300px';
            toast.textContent = (isAboutThisCard ? "👁️ Cette carte : " : "") + msg;
            document.body.appendChild(toast);

            setTimeout(() => toast.remove(), 4000);
        }
    </script>
}