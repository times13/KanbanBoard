    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
@model KanbanBoard.LibrairieMetier.ViewModels.EditCardViewModel

@{
    ViewData["Title"] = "Modifier la carte";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-7">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>✏️ Modifier la carte</h2>
            <a asp-controller="Board" asp-action="Details" asp-route-id="@Model.BoardId" class="btn btn-outline-secondary btn-sm">
                ← Retour au tableau
            </a>
        </div>

        @* ============ Formulaire d'édition ============ *@
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="BoardId" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" autofocus />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Priority" class="form-label"></label>
                    <select asp-for="Priority" class="form-select">
                        <option value="Low">🟢 Basse</option>
                        <option value="Medium">🟡 Moyenne</option>
                        <option value="High">🟠 Haute</option>
                        <option value="Critical">🔴 Critique</option>
                    </select>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="DueDate" class="form-label"></label>
                    <input asp-for="DueDate" type="date" class="form-control" />
                    <span asp-validation-for="DueDate" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="AssigneeId" class="form-label"></label>
                    <select asp-for="AssigneeId" class="form-select">
                        <option value="">— Personne —</option>
                        @foreach (var member in Model.AvailableMembers)
                        {
                            <option value="@member.UserId">
                                @member.Username (@member.Role)
                            </option>
                        }
                    </select>
                    <span asp-validation-for="AssigneeId" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">💾 Enregistrer</button>
            </div>
        </form>

    @if (ViewData["IsAdmin"] is true)
    {
            @* Formulaire pour la suppression (HTML interdit les forms imbriqués) *@
            <form asp-action="Delete" method="post"
            class="mt-3"
              onsubmit="return confirm('⚠️ Supprimer définitivement cette carte ?\n\n« @Model.Title »');">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="boardId" value="@Model.BoardId" />
            <button type="submit" class="btn btn-outline-danger btn-sm">🗑️ Supprimer cette carte</button>
        </form>
    }

        @* ============ Section commentaires ============ *@
        <hr class="my-5" />

        <div class="row justify-content-center">
            <div class="col-md-12">
                <h4 class="mb-3">💬 Commentaires <span class="badge bg-secondary">@Model.Comments.Count</span></h4>

                @* Formulaire ajout commentaire *@
                <form asp-controller="Comment" asp-action="Add" method="post" class="mb-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="cardId" value="@Model.Id" />
                    <input type="hidden" name="boardId" value="@Model.BoardId" />

                    <div class="mb-2">
                        <textarea name="content" class="form-control"
                                  rows="2" maxlength="2000"
                                  placeholder="Écrire un commentaire..."
                                  required></textarea>
                    </div>
                    <button type="submit" class="btn btn-sm btn-primary">Commenter</button>
                </form>

                @* Liste des commentaires *@
                @if (!Model.Comments.Any())
                {
                    <p class="text-muted text-center py-3">Aucun commentaire pour cette carte.</p>
                }
                else
                {
                    var currentUserId = ViewData["CurrentUserId"] as int? ?? 0;
                    var isAdmin = ViewData["IsAdmin"] is true;

                    foreach (var comment in Model.Comments)
                    {
                        var canDelete = comment.AuthorId == currentUserId || isAdmin;

                        <div class="card mb-2 shadow-sm">
                            <div class="card-body py-2">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <strong>@comment.AuthorUsername</strong>
                                        <small class="text-muted ms-2">
                                            @comment.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                        </small>
                                    </div>
                                    @if (canDelete)
                                    {
                                        <form asp-controller="Comment" asp-action="Delete" method="post"
                                              onsubmit="return confirm('Supprimer ce commentaire ?');"
                                              class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@comment.Id" />
                                            <button type="submit" class="btn btn-sm btn-link text-danger p-0"
                                                    title="Supprimer">
                                                ✕
                                            </button>
                                        </form>
                                    }
                                </div>
                                <p class="mb-0 mt-1" style="white-space: pre-wrap;">@comment.Content</p>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}