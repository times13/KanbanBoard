<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KanbanBoard.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KanbanBoard.Web.styles.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">KanbanBoard.Web</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                @* <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                </div> *@
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Accueil</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Board" asp-action="MyBoards">📋 Mes tableaux</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Confidentialité</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @* ============ Cloche notifications ============ *@
                            <li class="nav-item dropdown me-2">
                                <a class="nav-link position-relative" href="#"
                                   id="notifBell" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false"
                                   style="font-size: 1.3rem;">
                                    🔔
                                    <span id="notifBadge"
                                          class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                          style="font-size: 0.65rem; display: none;">
                                        0
                                    </span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow"
                                    style="width: 360px; max-height: 480px; overflow-y: auto;"
                                    aria-labelledby="notifBell">
                                    <li class="dropdown-header d-flex justify-content-between align-items-center">
                                        <strong>Notifications</strong>
                                        <button id="markAllReadBtn" type="button"
                                                class="btn btn-sm btn-link p-0"
                                                style="font-size: 0.8rem;">
                                            Tout marquer comme lu
                                        </button>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li id="notifList">
                                        <div class="text-center text-muted py-3 small">
                                            Chargement...
                                        </div>
                                    </li>
                                </ul>
                            </li>

                            <li class="nav-item">
                                <span class="nav-link text-dark">👤 @User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="form-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link nav-link text-dark border-0">Déconnexion</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Connexion</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Register">Inscription</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - KanbanBoard.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const bellBadge = document.getElementById('notifBadge');
                const notifList = document.getElementById('notifList');
                const markAllBtn = document.getElementById('markAllReadBtn');
                const antiToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                // ============ Charger les notifs ============
                async function loadNotifications() {
                    try {
                        const response = await fetch('/Notification/Recent', {
                            method: 'GET',
                            headers: { 'Accept': 'application/json' }
                        });

                        if (!response.ok) {
                            notifList.innerHTML = '<div class="text-center text-muted py-3 small">Erreur de chargement</div>';
                            return;
                        }

                        const data = await response.json();
                        updateBadge(data.unreadCount);
                        renderNotifications(data.notifications);
                    } catch (err) {
                        console.error('Erreur fetch notifs:', err);
                    }
                }

                // ============ Mettre à jour le badge ============
                function updateBadge(count) {
                    if (count > 0) {
                        bellBadge.textContent = count > 99 ? '99+' : count;
                        bellBadge.style.display = 'inline-block';
                    } else {
                        bellBadge.style.display = 'none';
                    }
                }

                // ============ Afficher la liste ============
                function renderNotifications(notifs) {
                    if (!notifs || notifs.length === 0) {
                        notifList.innerHTML = '<div class="text-center text-muted py-3 small">Aucune notification</div>';
                        return;
                    }

                    const html = notifs.map(n => {
                        const dateStr = new Date(n.createdAt).toLocaleString('fr-FR', {
                            day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit'
                        });
                        const bgClass = n.isRead ? '' : 'bg-light';
                        const fwClass = n.isRead ? 'fw-normal' : 'fw-bold';
                        const linkUrl = n.boardId ? `/Board/Details/${n.boardId}` : '#';

                        return `
                            <a href="#" class="dropdown-item notif-item ${bgClass}"
                               data-notif-id="${n.id}"
                               data-target-url="${linkUrl}">
                                <div class="${fwClass} small">${escapeHtml(n.message)}</div>
                                <div class="text-muted" style="font-size: 0.7rem;">${dateStr}</div>
                            </a>`;
                    }).join('<li><hr class="dropdown-divider"/></li>');

                    notifList.innerHTML = html;

                    // Event sur chaque notif
                    document.querySelectorAll('.notif-item').forEach(item => {
                        item.addEventListener('click', async function (e) {
                            e.preventDefault();
                            const notifId = this.dataset.notifId;
                            const url = this.dataset.targetUrl;
                            await markAsRead(notifId);
                            if (url && url !== '#') window.location.href = url;
                        });
                    });
                }

                // ============ Marquer une notif comme lue ============
                async function markAsRead(notifId) {
                    try {
                        await fetch('/Notification/MarkAsRead', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded',
                                'RequestVerificationToken': antiToken || ''
                            },
                            body: `id=${encodeURIComponent(notifId)}`
                        });
                    } catch (err) {
                        console.error('Erreur markAsRead:', err);
                    }
                }

                // ============ Tout marquer comme lu ============
                if (markAllBtn) {
                    markAllBtn.addEventListener('click', async function (e) {
                        e.preventDefault();
                        e.stopPropagation();
                        try {
                            await fetch('/Notification/MarkAllAsRead', {
                                method: 'POST',
                                headers: { 'RequestVerificationToken': antiToken || '' }
                            });
                            loadNotifications();
                        } catch (err) {
                            console.error('Erreur markAllAsRead:', err);
                        }
                    });
                }

                // ============ Helper : échapper le HTML ============
                function escapeHtml(text) {
                    const div = document.createElement('div');
                    div.textContent = text;
                    return div.innerHTML;
                }

                // ============ SignalR : écoute des nouvelles notifs ============
                const notifConnection = new signalR.HubConnectionBuilder()
                    .withUrl('/kanbanHub')
                    .withAutomaticReconnect()
                    .configureLogging(signalR.LogLevel.Warning)
                    .build();

                notifConnection.on('NotificationReceived', function (payload) {
                    console.log('🔔 Nouvelle notification:', payload);

                    // Recharge la liste + badge
                    loadNotifications();

                    // Toast léger en plus pour signaler visuellement
                    showNotifToast(payload.message);
                });

                notifConnection.start()
                    .then(() => console.log('✅ SignalR notifications connecté'))
                    .catch(err => console.error('❌ SignalR notif erreur:', err));

                // ============ Toast notification ============
                function showNotifToast(message) {
                    const toast = document.createElement('div');
                    toast.className = 'position-fixed top-0 end-0 m-3 alert alert-warning shadow';
                    toast.style.zIndex = 10000;
                    toast.style.minWidth = '300px';
                    toast.style.maxWidth = '400px';
                    toast.innerHTML = `🔔 <strong>Nouvelle notification</strong><br/><small>${escapeHtml(message)}</small>`;
                    document.body.appendChild(toast);
                    setTimeout(() => toast.remove(), 5000);
                }

                // ============ Chargement initial ============
                loadNotifications();
            });
        </script>

        @* Antiforgery token global pour les fetch JS *@
        <form id="antiForgeryForm" style="display: none;">@Html.AntiForgeryToken()</form>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
