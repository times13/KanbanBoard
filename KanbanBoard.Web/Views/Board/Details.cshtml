@{
}
@model KanbanBoard.LibrairieMetier.ViewModels.KanbanBoardViewModel

@{
    ViewData["Title"] = Model.Title;
}

<div class="d-flex justify-content-between align-items-center mb-3 mt-3">
    <div>
        <a asp-action="MyBoards" class="text-decoration-none text-muted small">← Mes tableaux</a>
        <h2 class="mb-0 mt-1">@Model.Title</h2>
        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <p class="text-muted small mb-0">@Model.Description</p>
        }
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="kanban-board d-flex gap-3 overflow-auto pb-3" style="min-height: 70vh;">
    @foreach (var col in Model.Columns)
    {
        <div class="kanban-column flex-shrink-0" style="width: 300px;">
            <div class="card h-100 bg-light">
                <div class="card-header d-flex justify-content-between align-items-center bg-white">
                    <h6 class="mb-0">@col.Title</h6>
                    <div class="d-flex gap-2 align-items-center">
                        <span class="badge bg-secondary">@col.Cards.Count</span>
                        @if (Model.IsAdmin)
                        {
                            <div class="dropdown">
                                <button class="btn btn-sm btn-link text-muted p-0 border-0" data-bs-toggle="dropdown" aria-expanded="false">
                                    ⋮
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <button class="dropdown-item btn-rename-column"
                                                data-column-id="@col.Id"
                                                data-column-title="@col.Title">
                                            ✏️ Renommer
                                        </button>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <button class="dropdown-item text-danger btn-delete-column"
                                                data-column-id="@col.Id"
                                                data-column-title="@col.Title"
                                                data-card-count="@col.Cards.Count">
                                            🗑️ Supprimer
                                        </button>
                                    </li>
                                </ul>
                            </div>
                        }
                    </div>
                </div>
                <div class="card-body p-2" data-column-id="@col.Id">
                    @foreach (var card in col.Cards)
                    {
                        <a asp-controller="Card" asp-action="Edit" asp-route-id="@card.Id"
                           class="text-decoration-none text-dark">
                            <div class="card mb-2 shadow-sm kanban-card" data-card-id="@card.Id">
                                <div class="card-body p-2">
                                    <p class="mb-1 small fw-bold">@card.Title</p>
                                    @if (!string.IsNullOrWhiteSpace(card.Description))
                                    {
                                        <p class="mb-1 small text-muted">
                                            @(card.Description.Length > 80 ? card.Description.Substring(0, 80) + "..." : card.Description)
                                        </p>
                                    }
                                    <div class="d-flex justify-content-between align-items-center mt-2">
                                        @{
                                            var priorityClass = card.Priority switch
                                            {
                                                "Critical" => "bg-danger",
                                                "High" => "bg-warning text-dark",
                                                "Low" => "bg-info text-dark",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @priorityClass small">@card.Priority</span>
                                        @if (card.AssigneeUsername != null)
                                        {
                                            <small class="text-muted">👤 @card.AssigneeUsername</small>
                                        }
                                    </div>
                                    @if (card.DueDate.HasValue)
                                    {
                                        <small class="text-muted d-block mt-1">📅 @card.DueDate.Value.ToString("dd/MM/yyyy")</small>
                                    }
                                </div>
                            </div>
                        </a>
                    }
                </div>
                @if (Model.CanEdit)
                {
                    <div class="card-footer bg-white">
                        <button class="btn btn-sm btn-outline-primary w-100"
                                data-bs-toggle="modal"
                                data-bs-target="#createCardModal"
                                data-column-id="@col.Id"
                                data-column-title="@col.Title">
                            + Ajouter une carte
                        </button>
                    </div>
                }
            </div>
        </div>
    }
    @if (Model.IsAdmin)
    {
        <div class="kanban-column flex-shrink-0" style="width: 300px;">
            <button class="btn btn-outline-secondary w-100 h-100 d-flex align-items-center justify-content-center"
                    style="border-style: dashed; min-height: 100px;"
                    data-bs-toggle="modal"
                    data-bs-target="#createColumnModal">
                ➕ Ajouter une colonne
            </button>
        </div>
    }
</div>

@* ============ Modal de création de carte ============ *@
<div class="modal fade" id="createCardModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Card" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="BoardId" value="@Model.BoardId" />
                <input type="hidden" name="ColumnId" id="modalColumnId" />

                <div class="modal-header">
                    <h5 class="modal-title">Nouvelle carte dans <span id="modalColumnName" class="text-primary"></span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="mb-3">
                        <label for="cardTitle" class="form-label">Titre <span class="text-danger">*</span></label>
                        <input type="text" name="Title" id="cardTitle" class="form-control" maxlength="200" required autofocus />
                    </div>
                    <div class="mb-3">
                        <label for="cardDescription" class="form-label">Description (facultative)</label>
                        <textarea name="Description" id="cardDescription" class="form-control" rows="3" maxlength="4000"></textarea>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-primary">Créer la carte</button>
                </div>
            </form>
        </div>
    </div>
</div>

@if (Model.IsAdmin)
{
    @* ============ Modal Créer Colonne ============ *@
    <div class="modal fade" id="createColumnModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-controller="Column" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="boardId" value="@Model.BoardId" />

                    <div class="modal-header">
                        <h5 class="modal-title">Nouvelle colonne</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <label for="newColumnTitle" class="form-label">Titre de la colonne</label>
                        <input type="text" name="title" id="newColumnTitle" class="form-control" maxlength="100" required autofocus />
                        <small class="text-muted">Ex: « En revue », « Bloqué », « Tests »</small>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
                        <button type="submit" class="btn btn-primary">Créer</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @* ============ Modal Renommer Colonne ============ *@
    <div class="modal fade" id="renameColumnModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-controller="Column" asp-action="Rename" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="renameColumnId" />

                    <div class="modal-header">
                        <h5 class="modal-title">Renommer la colonne</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <label for="renameColumnTitle" class="form-label">Nouveau titre</label>
                        <input type="text" name="newTitle" id="renameColumnTitle" class="form-control" maxlength="100" required />
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
                        <button type="submit" class="btn btn-primary">Renommer</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @* ============ Modal Supprimer Colonne ============ *@
    <div class="modal fade" id="deleteColumnModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-controller="Column" asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deleteColumnId" />

                    <div class="modal-header">
                        <h5 class="modal-title text-danger">⚠️ Supprimer la colonne ?</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p>Vous êtes sur le point de supprimer la colonne <strong id="deleteColumnTitle"></strong>.</p>
                        <div id="deleteColumnWarning" class="alert alert-warning" style="display: none;">
                            <strong>Attention :</strong> cette colonne contient <span id="deleteColumnCardCount"></span> carte(s) qui seront <strong>définitivement supprimées</strong>.
                        </div>
                        <p class="text-muted small mb-0">Cette action est <strong>irréversible</strong>.</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
                        <button type="submit" class="btn btn-danger">Supprimer définitivement</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Styles {
    <style>
        .kanban-board {
            scroll-behavior: smooth;
        }

        .kanban-column {
            min-width: 300px;
        }

        .kanban-card {
            cursor: pointer;
            transition: transform 0.1s;
        }

            .kanban-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(0,0,0,0.1) !important;
            }
    </style>
}

@section Scripts {
    <script>
        // ============ Modal créer carte (existant) ============
        document.addEventListener('DOMContentLoaded', function () {
            var modal = document.getElementById('createCardModal');
            modal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;
                var columnId = button.getAttribute('data-column-id');
                var columnTitle = button.getAttribute('data-column-title');

                document.getElementById('modalColumnId').value = columnId;
                document.getElementById('modalColumnName').textContent = columnTitle;
                document.getElementById('cardTitle').value = '';
                document.getElementById('cardDescription').value = '';
            });

            // ============ SignalR : connexion temps réel ============
            const boardId = @Model.BoardId;

            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/kanbanHub")
                .withAutomaticReconnect()
                .build();

            // Réception d'un évènement "BoardChanged"
            connection.on("BoardChanged", function (payload) {
                console.log("📡 BoardChanged reçu :", payload);

                // Affiche un toast non-bloquant
                showLiveNotification(payload);

                // Recharge la page automatiquement après 1s pour voir les changements
                // (version simple — Jour 3 on remplacera par une mise à jour DOM ciblée)
                setTimeout(() => location.reload(), 1500);
            });

            // Démarrer la connexion puis rejoindre le groupe du board
            connection.start()
                .then(() => {
                    console.log("✅ SignalR connecté");
                    return connection.invoke("JoinBoard", boardId);
                })
                .then(() => console.log(`✅ Joint le board ${boardId}`))
                .catch(err => console.error("❌ SignalR erreur :", err));

            // Quitter le groupe quand on quitte la page (best effort)
            window.addEventListener("beforeunload", () => {
                connection.invoke("LeaveBoard", boardId).catch(() => {});
            });

            // ============ Modal Renommer Colonne ============
            document.querySelectorAll('.btn-rename-column').forEach(btn => {
                btn.addEventListener('click', function () {
                    document.getElementById('renameColumnId').value = this.dataset.columnId;
                    document.getElementById('renameColumnTitle').value = this.dataset.columnTitle;
                    new bootstrap.Modal(document.getElementById('renameColumnModal')).show();
                });
            });

            // ============ Modal Supprimer Colonne ============
            document.querySelectorAll('.btn-delete-column').forEach(btn => {
                btn.addEventListener('click', function () {
                    const cardCount = parseInt(this.dataset.cardCount, 10);
                    document.getElementById('deleteColumnId').value = this.dataset.columnId;
                    document.getElementById('deleteColumnTitle').textContent = '« ' + this.dataset.columnTitle + ' »';

                    const warning = document.getElementById('deleteColumnWarning');
                    if (cardCount > 0) {
                        document.getElementById('deleteColumnCardCount').textContent = cardCount;
                        warning.style.display = 'block';
                    } else {
                        warning.style.display = 'none';
                    }

                    new bootstrap.Modal(document.getElementById('deleteColumnModal')).show();
                });
            });

        });

        // ============ Helper : toast notification ============
        function showLiveNotification(payload) {
            const messages = {
                "CardCreated":  `🆕 Nouvelle carte « ${payload.title} » par ${payload.triggeredBy}`,
                "CardUpdated":  `✏️ Carte « ${payload.title} » modifiée par ${payload.triggeredBy}`,
                "CardDeleted":  `🗑️ Une carte a été supprimée par ${payload.triggeredBy}`,
                "ColumnCreated": `➕ Nouvelle colonne « ${payload.title} » par ${payload.triggeredBy}`,
                "ColumnRenamed": `✏️ Colonne renommée en « ${payload.title} » par ${payload.triggeredBy}`,
                "ColumnDeleted": `🗑️ Une colonne a été supprimée par ${payload.triggeredBy}`
            };

            const msg = messages[payload.action] || `Mise à jour : ${payload.action}`;

            const toast = document.createElement('div');
            toast.className = 'position-fixed top-0 end-0 m-3 alert alert-info shadow';
            toast.style.zIndex = 9999;
            toast.style.minWidth = '300px';
            toast.textContent = msg;
            document.body.appendChild(toast);

            setTimeout(() => toast.remove(), 4000);
        }
    </script>
}