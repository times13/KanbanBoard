@{
}
@model KanbanBoard.LibrairieMetier.ViewModels.KanbanBoardViewModel

@{
    ViewData["Title"] = Model.Title;
}

<div class="d-flex justify-content-between align-items-center mb-3 mt-3">
    <div>
        <a asp-action="MyBoards" class="text-decoration-none text-muted small">← Mes tableaux</a>
        <h2 class="mb-0 mt-1">@Model.Title</h2>
        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <p class="text-muted small mb-0">@Model.Description</p>
        }
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="kanban-board d-flex gap-3 overflow-auto pb-3" style="min-height: 70vh;">
    @foreach (var col in Model.Columns)
    {
        <div class="kanban-column flex-shrink-0" style="width: 300px;">
            <div class="card h-100 bg-light">
                <div class="card-header d-flex justify-content-between align-items-center bg-white">
                    <h6 class="mb-0">@col.Title</h6>
                    <span class="badge bg-secondary">@col.Cards.Count</span>
                </div>
                <div class="card-body p-2" data-column-id="@col.Id">
                    @foreach (var card in col.Cards)
                    {
                        <a asp-controller="Card" asp-action="Edit" asp-route-id="@card.Id"
                           class="text-decoration-none text-dark">
                            <div class="card mb-2 shadow-sm kanban-card" data-card-id="@card.Id">
                                <div class="card-body p-2">
                                    <p class="mb-1 small fw-bold">@card.Title</p>
                                    @if (!string.IsNullOrWhiteSpace(card.Description))
                                    {
                                        <p class="mb-1 small text-muted">
                                            @(card.Description.Length > 80 ? card.Description.Substring(0, 80) + "..." : card.Description)
                                        </p>
                                    }
                                    <div class="d-flex justify-content-between align-items-center mt-2">
                                        @{
                                            var priorityClass = card.Priority switch
                                            {
                                                "Critical" => "bg-danger",
                                                "High" => "bg-warning text-dark",
                                                "Low" => "bg-info text-dark",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @priorityClass small">@card.Priority</span>
                                        @if (card.AssigneeUsername != null)
                                        {
                                            <small class="text-muted">👤 @card.AssigneeUsername</small>
                                        }
                                    </div>
                                    @if (card.DueDate.HasValue)
                                    {
                                        <small class="text-muted d-block mt-1">📅 @card.DueDate.Value.ToString("dd/MM/yyyy")</small>
                                    }
                                </div>
                            </div>
                        </a>
                    }
                </div>
                @if (Model.CanEdit)
                {
                    <div class="card-footer bg-white">
                        <button class="btn btn-sm btn-outline-primary w-100"
                                data-bs-toggle="modal"
                                data-bs-target="#createCardModal"
                                data-column-id="@col.Id"
                                data-column-title="@col.Title">
                            + Ajouter une carte
                        </button>
                    </div>
                }
            </div>
        </div>
    }
</div>

@* ============ Modal de création de carte ============ *@
<div class="modal fade" id="createCardModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Card" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="BoardId" value="@Model.BoardId" />
                <input type="hidden" name="ColumnId" id="modalColumnId" />

                <div class="modal-header">
                    <h5 class="modal-title">Nouvelle carte dans <span id="modalColumnName" class="text-primary"></span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="mb-3">
                        <label for="cardTitle" class="form-label">Titre <span class="text-danger">*</span></label>
                        <input type="text" name="Title" id="cardTitle" class="form-control" maxlength="200" required autofocus />
                    </div>
                    <div class="mb-3">
                        <label for="cardDescription" class="form-label">Description (facultative)</label>
                        <textarea name="Description" id="cardDescription" class="form-control" rows="3" maxlength="4000"></textarea>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-primary">Créer la carte</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .kanban-board {
            scroll-behavior: smooth;
        }

        .kanban-column {
            min-width: 300px;
        }

        .kanban-card {
            cursor: pointer;
            transition: transform 0.1s;
        }

            .kanban-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(0,0,0,0.1) !important;
            }
    </style>
}

@section Scripts {
    <script>
        // Pré-remplit le modal "Créer une carte" avec la bonne colonne
        document.addEventListener('DOMContentLoaded', function () {
            var modal = document.getElementById('createCardModal');
            modal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;
                var columnId = button.getAttribute('data-column-id');
                var columnTitle = button.getAttribute('data-column-title');

                document.getElementById('modalColumnId').value = columnId;
                document.getElementById('modalColumnName').textContent = columnTitle;
                document.getElementById('cardTitle').value = '';
                document.getElementById('cardDescription').value = '';
            });
        });
    </script>
}