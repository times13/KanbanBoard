@{
}

@model List<KanbanBoard.LibrairieMetier.ViewModels.BoardListItemViewModel>

@{
    ViewData["Title"] = "Mes tableaux";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2>📋 Mes tableaux</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Nouveau tableau
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="text-center py-5">
        <p class="text-muted">Vous n'avez aucun tableau pour le moment.</p>
        <a asp-action="Create" class="btn btn-primary mt-2">Créer mon premier tableau</a>
    </div>
}
else
{
    <div class="row">
        @foreach (var board in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">@board.Title</h5>
                        @if (!string.IsNullOrWhiteSpace(board.Description))
                        {
                            <p class="card-text text-muted small">
                                @(board.Description.Length > 100 ? board.Description.Substring(0, 100) + "..." : board.Description)
                            </p>
                        }
                        <div class="d-flex justify-content-between align-items-center text-muted small mt-3">
                            <span>👥 @board.OwnerUsername @(board.IsOwner ? "(vous)" : "")</span>
                            <span>🃏 @board.CardCount carte@(board.CardCount > 1 ? "s" : "")</span>
                        </div>
                    </div>
                    <div class="card-footer bg-white border-top-0">
                        <a asp-action="Details" asp-route-id="@board.Id" class="btn btn-outline-primary btn-sm w-100">
                            Ouvrir →
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}