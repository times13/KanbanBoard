@{
}

@model KanbanBoard.LibrairieMetier.ViewModels.CreateBoardViewModel

@{
    ViewData["Title"] = "Créer un tableau";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <h2 class="mb-4">📋 Nouveau tableau</h2>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" autofocus />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
                <small class="text-muted">À quoi sert ce tableau ? (facultatif)</small>
            </div>

            <div class="alert alert-info small">
                💡 Trois colonnes seront créées par défaut : <strong>À faire</strong>, <strong>En cours</strong>, <strong>Terminé</strong>.
                Tu pourras les modifier ensuite.
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Créer le tableau</button>
                <a asp-action="MyBoards" class="btn btn-outline-secondary">Annuler</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
